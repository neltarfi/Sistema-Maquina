  object zqMovLoteSacaria: TZQuery
    Connection = zConn
    SQL.Strings = (
      'SELECT'
      '         L."IDLoteSacaria" || '', '' || L."Nome" as Nome,'
      '         MovLoteSacaria."IDCliente",'
      '         MovLoteSacaria."IDMovLoteSacaria",'
      '         MovLoteSacaria."IDLoteSacaria",'
