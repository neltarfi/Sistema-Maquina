      '         MovLoteSacaria."QuanEntrada",'
      '         MovLoteSacaria."QuanSaida",'
      '         MovLoteSacaria."Status"'
      'FROM   MovLoteSacaria'
      'INNER JOIN LoteSacaria as L ON MovLoteSacaria."IDLoteSacaria" = L."IDLoteSacaria" '
      'order by MovLoteSacaria."Data"'
